{
  "name": "cap-serv-notif",
  "version": "1.0.0",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9.9.2",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "rcf": "rm -rf gen mta_archives && mbt build && cf deploy mta_archives/cap-serv-notif_1.0.0.mtar",
    "log": "cf logs cap-serv-notif-srv --recent",
    "watch-notifications": "cds watch --open notifications/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy cap-serv-notif --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "features": {
      "fiori_preview": true
    },
    "requires": {
      "auth": {
        "kind": "dummy"
      },
      "API_MAINTNOTIFICATION": {
        "kind": "odata-v2",
        "model": "srv/external/API_MAINTNOTIFICATION",
        "[production]": {
          "credentials": {
            "destination": "CXB400",
            "path": "/sap/opu/odata/sap/API_MAINTNOTIFICATION"
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/notifications"
  ]
}
